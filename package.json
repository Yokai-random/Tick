{
  "name": "tick",
  "version": "1.0.0",
  "description": "Claude Minecraft Launcher",
  "main": "electron/main.js",
  "author": "Tick",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron . --dev\"",
    "build": "vite build && electron-builder",
    "start": "vite build && electron ."
  },
  "dependencies": {
    "adm-zip": "^0.5.10",
    "archiver": "^5.3.2",
    "iconv-lite": "^0.7.2",
    "node-stream-zip": "^1.15.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "vite": "^5.0.10",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.cmcl.launcher",
    "productName": "Tick",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "icon/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "portable",
      "icon": "icon/icon.ico"
    }
  }
}
